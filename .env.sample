NODE_ENV=development

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E2E
E2E_BASE_URL=http://localhost:3000
E2E_TEST_USER_EMAIL=test@example.com
E2E_TEST_USER_PASSWORD=password

# Sentry
SENTRY_AUTH_TOKEN=sentry_auth_token
# Sentry DSN. When unset, Sentry.init is skipped (keep empty in local dev and E2E to avoid noise)
NEXT_PUBLIC_SENTRY_DSN=
# Sentry environment tag shown in the Sentry UI (e.g. development / production)
NEXT_PUBLIC_SENTRY_ENV=development
